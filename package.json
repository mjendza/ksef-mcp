{
  "name": "@mjendza/ksef-mcp",
  "version": "0.1.0",
  "description": "MCP server for read-only access to Polish KSeF (Krajowy System e-Faktur)",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/mjendza/ksef-mcp"
  },
  "bin": {
    "ksef-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "prepare": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:acceptance": "vitest run src/ksef/auth.acceptance.test.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "22.19.18",
    "cross-env": "10.1.0",
    "typescript": "5.9.3",
    "vitest": "4.1.6"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "ksef",
    "mcp",
    "e-faktura",
    "invoice",
    "poland"
  ],
  "license": "MIT"
}
